{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ABO",
  "version": "0.1.0",
  "identifier": "com.huanc.abo",
  "build": {
    "beforeDevCommand": "python3 scripts/build_tauri_sidecar.py && python3 scripts/dev_abo.py",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "python3 scripts/build_tauri_sidecar.py && VITE_ABO_API_PORT=8766 npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ABO — Another Brain Odyssey",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "transparent": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "windowEffects": {
          "effects": ["mica"],
          "state": "followsWindowActiveState"
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/abo-backend"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
